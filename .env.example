# Supabase connection string — required in every environment (no local
# fallback postgres). On a self-hosted Supabase behind Supavisor, the
# username has the tenant-id suffix: postgres.<tenant-id>. Tailnet IP
# is safe without TLS; public endpoints should use sslmode=require.
DATABASE_URL=postgresql://postgres.your-tenant-id:YOUR_DB_PASSWORD@100.75.202.73:5432/postgres?sslmode=disable

# Schema for app tables. Auto-created on startup. Default: domainwatcher.
# Use lowercase letters, digits, underscores only.
DB_SCHEMA=domainwatcher
PORT=8080

# Enricher API keys — sources skip themselves gracefully if absent.
# abuse.ch URLhaus and ThreatFox require a free Auth-Key as of 2024-11;
# register at https://auth.abuse.ch and set ABUSECH_AUTH_KEY below.
ABUSECH_AUTH_KEY=
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
OTX_API_KEY=
IPINFO_TOKEN=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=

# Alerts
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# DNS
# Comma-separated list of upstream resolvers (host:port). Defaults to
# 8.8.8.8/1.1.1.1/9.9.9.9. When running in Docker on macOS/Windows,
# set to 127.0.0.11:53 to use the Docker embedded DNS forwarder.
DNS_UPSTREAMS=

# Workers
DNS_WORKER_COUNT=50
ENRICHER_WORKER_COUNT=10
MAX_PERMUTATIONS=2000
SCAN_TIMEOUT_SECONDS=120

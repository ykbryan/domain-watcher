DATABASE_URL=postgres://domainwatch:domainwatch@localhost:5432/domainwatch?sslmode=disable
PORT=8080

# Enricher API keys — sources skip themselves gracefully if absent
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
OTX_API_KEY=
IPINFO_TOKEN=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=

# Alerts
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Workers
DNS_WORKER_COUNT=50
ENRICHER_WORKER_COUNT=10
MAX_PERMUTATIONS=2000
SCAN_TIMEOUT_SECONDS=120
